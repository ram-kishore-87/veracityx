{
  "manifest_version": 3,
  "name": "VeracityX - Misinformation Detector",
  "version": "1.0.0",
  "description": "Analyze webpage content for misinformation, bias, and credibility in real-time.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "VeracityX - Check this content"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
